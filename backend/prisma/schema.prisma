generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Sweet {
  id        Int      @id @default(autoincrement())
  name      String
  category  String?      // ✅ optional (prevents insert failure)
  price     Float
  quantity  Int
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  role      String   @default("USER") // ✅ correct default
}
